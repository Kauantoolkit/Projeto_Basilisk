{
  "name": "@basilisk/schemas",
  "version": "0.1.0",
  "description": "Schemas Zod reutilizáveis com tipos TypeScript inferidos",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@basilisk/config": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  },
  "sideEffects": false
}
